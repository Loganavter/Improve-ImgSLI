{
  "_format": {
    "doc": "Cross-language widget parity corpus. Each case describes a widget configuration in language-agnostic terms; both the Python (sli_ui_toolkit) and C++ (sli::toolkit) renderers build a widget from the same dict, force the requested state, paint into a PNG of the same canvas size, and the driver compares pixels.",
    "config_dict_keys": "text, variant, size, icon_size, toggle, scrollable, long_press_ms, menu, badge, show_underline, underline_color, underline_thickness, corner_radius",
    "states": "default | hover | pressed | checked | focused | disabled",
    "canvas": "[width, height] of the host QWidget the button is placed in (centered)",
    "diff_max_per_pixel": "max allowed mean per-pixel difference (0..255). 0.0 == pixel-identical."
  },
  "cases": [
    {
